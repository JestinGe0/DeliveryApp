# ============================================================
#  PEP Delivery Platform - Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never share or commit your .env file.
# ============================================================

# OpenRouteService API Key
# Required if ROUTING_BACKEND=ors, or as fallback when Valhalla is unavailable.
# Get a free key at: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_api_key_here

# Routing backend to use for road distances and durations.
# "valhalla"  - local Docker container (fast, no API costs, requires valhalla_uk setup)
# "ors"       - OpenRouteService cloud API (requires ORS_API_KEY above)
ROUTING_BACKEND=valhalla

# URL for the local Valhalla routing engine (only used when ROUTING_BACKEND=valhalla)
VALHALLA_URL=http://localhost:8002

# ---- Authentication ----
# Secret key used to sign JWT session tokens.
# Change this to a long random string before going to production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret

# ---- Vendor / Plan Management ----
# Secret used by the software vendor to set a customer's subscription plan remotely.
# Only the vendor should know this value. Generate with the same command as JWT_SECRET.
# Set the plan via: curl -X PUT https://yourserver.com/api/plan \
#   -H "X-Vendor-Secret: YOUR_SECRET" \
#   -H "Content-Type: application/json" \
#   -d '{"planKey":"pro"}'
# Valid plan keys: free, starter, pro, enterprise
VENDOR_SECRET=change-this-to-a-different-long-random-secret

# ---- HTTPS ----
# Set to true to serve the app over HTTPS (recommended for network access).
# Run generate-cert.bat first to create the certificate files.
HTTPS_ENABLED=false

# Port for the HTTPS server (default: 3443). HTTP on PORT auto-redirects here.
HTTPS_PORT=3443

# Port for the HTTP server (redirects to HTTPS when HTTPS_ENABLED=true).
PORT=3000

# Paths to your TLS certificate files (leave blank to use the auto-generated defaults).
# SSL_KEY_PATH=server/certs/server.key
# SSL_CERT_PATH=server/certs/server.cert
