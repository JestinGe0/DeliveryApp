# ============================================================
#  PEP Delivery Platform — Docker Environment
#  Copy this file to .env and fill in your values.
#  Keep .env private — never share or commit it.
# ============================================================

# ---- Security (generate with: openssl rand -hex 48) ----
JWT_SECRET=change-this-to-a-long-random-secret
VENDOR_SECRET=change-this-to-a-different-long-random-secret

# ---- Routing ----
# Option A — OpenRouteService (no local install needed)
ROUTING_BACKEND=ors
ORS_API_KEY=your_ors_api_key_here

# Option B — Local Valhalla container (faster, no API costs)
# ROUTING_BACKEND=valhalla
# VALHALLA_URL=http://valhalla:8002

# ---- HTTPS ----
HTTPS_ENABLED=true
HTTPS_PORT=3443
PORT=3000
